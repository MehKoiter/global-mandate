generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────

enum TerrainType {
  PLAINS
  FOREST
  MOUNTAIN
  WATER
  DESERT
  URBAN
}

enum BuildingType {
  COMMAND_CENTER
  COMM_CENTER
  WAREHOUSE
  TOC
  LIGHT_VEHICLE_SHOP
  HEAVY_FACTORY
  RADIO_TOWER
  BUNKER
  HYDRO_BAY
  BARRACKS
}

enum SquadStatus {
  STAGING
  DEPLOYED
  IN_COMBAT
  RETREATING
  RETURNING
}

// ──────────────────────────────────────────────
// Layer 1 — Players
// ──────────────────────────────────────────────

model Player {
  id                String   @id @default(uuid())
  username          String   @unique
  email             String   @unique
  passwordHash      String
  fuel              Int      @default(500)
  rations           Int      @default(500)
  steel             Int      @default(500)
  credits           Int      @default(1000)
  maxCommandPoints  Int      @default(20)
  usedCommandPoints Int      @default(0)
  lastActiveAt      DateTime @default(now())
  createdAt         DateTime @default(now())

  // Tutorial
  tutorialStep              Int       @default(0)
  tutorialComplete          Boolean   @default(false)
  newPlayerProtectionEndsAt DateTime?

  // Lazy evaluation — cached net resource flow, recalculated on change
  lastResourceCalculatedAt DateTime @default(now())
  fuelNetPerHour           Float    @default(0)
  rationsNetPerHour        Float    @default(0)
  steelNetPerHour          Float    @default(0)
  creditsNetPerHour        Float    @default(0)

  fob               FOB?
  units             Unit[]
  squads            Squad[]
  allianceMember    AllianceMember?
  zonesOwned        Zone[]    @relation("ZoneOwner")
  battlesAsAttacker Battle[]  @relation("BattleAttacker")
  battlesAsDefender Battle[]  @relation("BattleDefender")
  hallOfFame        HallOfFame[]
}

// ──────────────────────────────────────────────
// Layer 2 — Sectors & Zones
// ──────────────────────────────────────────────

model Sector {
  id    String @id @default(uuid())
  name  String
  q     Int
  r     Int

  zones Zone[]

  @@unique([q, r])
}

model Zone {
  id                  String    @id @default(uuid())
  name                String
  sectorId            String
  q                   Int
  r                   Int
  ownerPlayerId       String?
  capturedAt          DateTime?
  consolidationEndsAt DateTime?
  fortificationLevel  Int       @default(0)
  wallBonus           Int       @default(0)
  fuelPerHour         Int       @default(0)
  rationsPerHour      Int       @default(0)
  steelPerHour        Int       @default(0)
  creditsPerHour      Int       @default(0)
  hasRoad             Boolean   @default(false)
  bridgeDestroyed     Boolean   @default(false)
  terrainType         TerrainType @default(PLAINS)

  // Signal Chain — broken chain yields 50% resources
  isConnected        Boolean @default(true)
  signalSourceZoneId String?

  sector           Sector       @relation(fields: [sectorId], references: [id])
  owner            Player?      @relation("ZoneOwner", fields: [ownerPlayerId], references: [id])
  units            Unit[]
  squads           Squad[]
  bunkerSlots      BunkerSlot[]
  battles          Battle[]
  inboundMovements Movement[]   @relation("MovementDestination")

  @@index([ownerPlayerId])
  @@index([sectorId])
}

// ──────────────────────────────────────────────
// Layer 3 — FOB & Buildings
// ──────────────────────────────────────────────

model FOB {
  id       String @id @default(uuid())
  playerId String @unique
  zoneId   String @unique

  player    Player     @relation(fields: [playerId], references: [id])
  buildings Building[]
  squads    Squad[]
}

model Building {
  id                     String       @id @default(uuid())
  fobId                  String
  buildingType           BuildingType
  level                  Int          @default(1)
  isUpgrading            Boolean      @default(false)
  upgradeEndsAt          DateTime?
  isOperational          Boolean      @default(true)
  maintenanceFuelPerHour Int          @default(0)

  fob FOB @relation(fields: [fobId], references: [id])

  @@unique([fobId, buildingType])
  @@index([fobId])
}

// ──────────────────────────────────────────────
// Layer 4 — Units
// ──────────────────────────────────────────────

model Unit {
  id            String  @id @default(uuid())
  ownerId       String
  unitType      String
  quantity      Int     @default(1)
  healthPct     Float   @default(100)
  morale        Float   @default(1.0)
  currentZoneId String?
  status          String    @default("IDLE") // IDLE | MOVING | IN_BATTLE | GARRISONING | TRAINING
  trainingEndsAt  DateTime?
  cargoCapacity   Int       @default(0)
  cargoUsed     Int     @default(0)

  owner       Player      @relation(fields: [ownerId], references: [id])
  currentZone Zone?       @relation(fields: [currentZoneId], references: [id])
  movements   Movement[]
  bunkerSlot  BunkerSlot?

  @@index([ownerId])
  @@index([currentZoneId, status])
}

// ──────────────────────────────────────────────
// Layer 4b — Squads
// A named group of units deployed from a FOB with its own resource reserves.
// ──────────────────────────────────────────────

model Squad {
  id            String      @id @default(uuid())
  name          String
  fobId         String
  ownerId       String
  currentZoneId String?
  status        SquadStatus @default(STAGING)
  rationsHeld   Int         @default(0)
  fuelHeld      Int         @default(0)
  createdAt     DateTime    @default(now())

  fob         FOB     @relation(fields: [fobId], references: [id])
  owner       Player  @relation(fields: [ownerId], references: [id])
  currentZone Zone?   @relation(fields: [currentZoneId], references: [id])

  @@index([ownerId])
  @@index([fobId])
}

// ──────────────────────────────────────────────
// Layer 4c — Bunker Slots
// Tracks units currently sheltered in a bunker.
// shelterPriority mirrors the unit's CP cost — higher CP = higher priority.
// ──────────────────────────────────────────────

model BunkerSlot {
  id              String @id @default(uuid())
  unitId          String @unique
  zoneId          String
  shelterPriority Int    @default(0)

  unit Unit @relation(fields: [unitId], references: [id])
  zone Zone @relation(fields: [zoneId], references: [id])

  @@index([zoneId])
}

// ──────────────────────────────────────────────
// Layer 5 — Movement Queue
// ──────────────────────────────────────────────

model Movement {
  id                String    @id @default(uuid())
  unitId            String
  ownerId           String
  originZoneId      String
  destinationZoneId String
  departedAt        DateTime  @default(now())
  arrivalAt         DateTime
  isCancelled       Boolean   @default(false)
  arrivedAt         DateTime?

  unit            Unit   @relation(fields: [unitId], references: [id])
  destinationZone Zone   @relation("MovementDestination", fields: [destinationZoneId], references: [id])

  @@index([unitId])
  @@index([destinationZoneId])
  @@index([ownerId])
}

// ──────────────────────────────────────────────
// Layer 6 — Scouting
// ──────────────────────────────────────────────

model ScoutReport {
  id           String   @id @default(uuid())
  scouterId    String
  targetZoneId String
  reportedAt   DateTime @default(now())
  unitSnapshot Json
  expiresAt    DateTime

  @@index([scouterId])
  @@index([targetZoneId])
}

// ──────────────────────────────────────────────
// Layer 7 — Combat & Battle Reports
// ──────────────────────────────────────────────

model Battle {
  id               String    @id @default(uuid())
  zoneId           String
  attackerPlayerId String
  defenderPlayerId String?
  outcome          String?   // ATTACKER_VICTORY | DEFENDER_VICTORY | DRAW
  resolvedAt       DateTime?
  zoneCaptured     Boolean   @default(false)
  fuelSpoils       Int       @default(0)
  steelSpoils      Int       @default(0)
  rationsSpoils    Int       @default(0)
  creditsSpoils    Int       @default(0)
  createdAt        DateTime  @default(now())

  zone     Zone          @relation(fields: [zoneId], references: [id])
  attacker Player        @relation("BattleAttacker", fields: [attackerPlayerId], references: [id])
  defender Player?       @relation("BattleDefender", fields: [defenderPlayerId], references: [id])
  rounds   BattleRound[]
  raidLog  RaidLog?

  @@index([zoneId])
  @@index([attackerPlayerId])
  @@index([outcome])
  @@index([resolvedAt, attackerPlayerId])
  @@index([resolvedAt, defenderPlayerId])
}

model BattleRound {
  id                  String   @id @default(uuid())
  battleId            String
  roundNumber         Int
  attackerDamageDealt Int
  defenderDamageDealt Int
  attackerLosses      Json
  defenderLosses      Json
  attackerMoraleEnd   Float
  defenderMoraleEnd   Float
  resolvedAt          DateTime @default(now())

  battle Battle @relation(fields: [battleId], references: [id])

  @@index([battleId])
}

// ──────────────────────────────────────────────
// Layer 7b — Raid Log
// Records resource siphoning outcome for siphon-raid battle type.
// One log per battle (battleId is unique).
// ──────────────────────────────────────────────

model RaidLog {
  id                String   @id @default(uuid())
  battleId          String   @unique
  attackerPlayerId  String
  defenderPlayerId  String
  steelSiphoned     Int      @default(0)
  fuelSiphoned      Int      @default(0)
  rationsSiphoned   Int      @default(0)
  creditsSiphoned   Int      @default(0)
  cargoCapacityUsed Int      @default(0)
  survivalFloor     Int      @default(0)
  createdAt         DateTime @default(now())

  battle Battle @relation(fields: [battleId], references: [id])

  @@index([attackerPlayerId])
  @@index([defenderPlayerId])
}

// ──────────────────────────────────────────────
// Layer 8 — Resource Transactions
// ──────────────────────────────────────────────

model ResourceTransaction {
  id        String   @id @default(uuid())
  playerId  String
  type      String   // PRODUCTION | TRIBUTE | SPOILS | TRADE | REWARD
  fuel      Int      @default(0)
  rations   Int      @default(0)
  steel     Int      @default(0)
  credits   Int      @default(0)
  note      String?
  createdAt DateTime @default(now())

  @@index([playerId])
}

// ──────────────────────────────────────────────
// Layer 9 — Alliances
// ──────────────────────────────────────────────

model Alliance {
  id        String   @id @default(uuid())
  name      String   @unique
  tag       String   @unique
  leaderId  String
  createdAt DateTime @default(now())

  members AllianceMember[]
}

model AllianceMember {
  id         String   @id @default(uuid())
  allianceId String
  playerId   String   @unique
  role       String   @default("MEMBER") // LEADER | OFFICER | MEMBER
  joinedAt   DateTime @default(now())

  alliance Alliance @relation(fields: [allianceId], references: [id])
  player   Player   @relation(fields: [playerId], references: [id])

  @@index([allianceId])
}

// ──────────────────────────────────────────────
// Layer 10 — Notifications
// ──────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  playerId  String
  type      String
  payload   Json
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([playerId, isRead])
}

// ──────────────────────────────────────────────
// Layer 11 — Hall of Fame
// ──────────────────────────────────────────────

model HallOfFame {
  id          String   @id @default(uuid())
  seasonId    String
  seasonName  String
  rank        Int
  playerId    String
  playerName  String
  allianceTag String?
  zonesOwned  Int
  battlesWon  Int
  endedAt     DateTime
  isWinner    Boolean  @default(false)

  player Player @relation(fields: [playerId], references: [id])

  @@index([seasonId])
  @@index([playerId])
}
